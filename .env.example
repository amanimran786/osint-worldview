# ─── osint-worldview ───────────────────────────────────
# Env vars for local docker-compose development.
# Copy to backend/.env and adjust as needed.

# Postgres (docker-compose)
POSTGRES_USER=osint
POSTGRES_PASSWORD=osint
POSTGRES_DB=osint

# Backend
DATABASE_URL=postgresql+psycopg2://osint:osint@db:5432/osint
REDIS_URL=redis://redis:6379/0
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=480
DATA_RETENTION_DAYS=30
ENV=dev
CORS_ORIGINS=http://localhost:3000,http://localhost:5174

# AI Features (optional — works without these, uses fallback analysis)
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Claude (Anthropic) — backend analysis engine (preferred)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini (Google) — frontend chat / UI assistant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
